{
  "name": "python-typescript-dev",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",

  "features": {
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.12"
    },
    "ghcr.io/devcontainers/features/node:2.0.0": {
      "version": "22"
    },
    "ghcr.io/anthropics/devcontainer-features/claude-code:1.0": {
    }

  },
  "containerEnv": {
    "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}",
    "ATLASSIAN_EMAIL": "${localEnv:ATLASSIAN_EMAIL}",
    "ATLASSIAN_API_TOKEN": "${localEnv:ATLASSIAN_API_TOKEN}",
    "ATLASSIAN_BASIC_AUTH": "${localEnv:ATLASSIAN_BASIC_AUTH}",
    "ATLASSIAN_URL": "${localEnv:ATLASSIAN_URL}",
    "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ]
    }
  },

  "postCreateCommand": "npm ci && pip install uv && chmod +x scripts/*.sh .claude/hooks/*.sh",
  "postStartCommand": "bash scripts/check-inbox.sh"
}